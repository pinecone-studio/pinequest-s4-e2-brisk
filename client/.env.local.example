# aegis-cctv-front (Next.js) — local environment variables
# Copy this file to .env.local:
#   cp .env.local.example .env.local
#
# This project holds NO secrets — server keys live in aegis-cctv-backend.

# ── Backend service location ─────────────────────────────────────────────────
# Used by lib/backendProxy.ts (app/api proxies) and the /api/camera-service/*
# rewrite in next.config.ts.
BACKEND_URL=http://localhost:3001

# ── Legacy camera-service origins (browser-exposed) ──────────────────────────
CAMERA_SERVICE_ORIGIN=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_HTTP=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_WS=ws://localhost:3001

# ── Demo toggles / static export (optional) ──────────────────────────────────
# NEXT_PUBLIC_DEMO_REALTIME=1
# STATIC_EXPORT=1   # disables app/api routes for a static export build
