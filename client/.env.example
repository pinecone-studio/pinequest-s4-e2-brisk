# aegis-cctv-front — environment variables
# Copy to .env.local (recommended) or .env.

# ── Backend / server URL ─────────────────────────────────────────────────────
# Used by lib/backendProxy.ts and evidence forwarding to POST /api/evidence.
BACKEND_URL=http://localhost:3001
# SERVER_URL=http://localhost:3001

# ── Gemini vision (Client-side API routes — never exposed to the browser) ───
# Obtain at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# ── Service-to-service auth ──────────────────────────────────────────────────
# Models → Client (POST /api/analyze)
# MODELS_CLIENT_SECRET=your-models-secret
# Client → Server (evidence save/list proxy)
# CLIENT_SERVER_SECRET=dev-secret

# ── Legacy camera-service origins (browser-exposed) ──────────────────────────
CAMERA_SERVICE_ORIGIN=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_HTTP=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_WS=ws://localhost:3001

# ── Demo toggles (optional) ──────────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_REALTIME=1
