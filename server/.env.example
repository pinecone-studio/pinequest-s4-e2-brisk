# aegis-cctv-backend — environment variables
# Copy to .env.local (recommended) or .env. Never commit real API keys.

# ── Gemini vision (required for live camera AI) ──────────────────────────────
# Server-side only — used by app/api/gemini/route.ts. The browser never sees it.
# Obtain at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY is accepted as a fallback for GEMINI_API_KEY
# GOOGLE_API_KEY=
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ── Local YOLO person gate (optional) ───────────────────────────────────────
# LitServe endpoint that pre-filters frames before Gemini (saves API budget).
# YOLO_API_URL=http://localhost:8000/predict

# ── Camera discovery (optional) ─────────────────────────────────────────────
# Comma-separated LAN IPs to probe for RTSP (port 554) during /api/discover/start.
# CAMERA_DISCOVERY_TARGETS=192.168.1.100,192.168.1.101

# ── FFmpeg (RTSP → MJPEG) ────────────────────────────────────────────────────
# Leave unset to use `ffmpeg` on PATH.
# FFMPEG_PATH=ffmpeg

# ── RTSP fallbacks (optional) ────────────────────────────────────────────────
# RTSP_PASSWORDS=123456,hk123456
# RTSP_PATHS=/Streaming/Channels/101,/live,/h264

# ── UniFi Protect (optional) ─────────────────────────────────────────────────
# UNIFI_API_KEY=
# UNIFI_PROTECT_HOST=
# UNIFI_PROTECT_VERIFY_TLS=false
# UNIFI_RTSP_CACHE_TTL_SECONDS=300

# ── Evidence API (Client → Server) ───────────────────────────────────────────
# Shared secret for POST /api/evidence (Bearer token). D1/R2 bindings land in #8.
# CLIENT_SERVER_SECRET=
