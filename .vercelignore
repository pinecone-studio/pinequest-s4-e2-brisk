# Keep the Vercel deployment lean: only ship what the browser needs.
# Runtime models (public/models/*.onnx) and the Next.js app are NOT ignored.
# Leading slashes anchor to repo root so public/models/ is never matched.

# Training data / ML artifacts — no runtime purpose
/models/
/runs/
/evidence/
/data/
/input/
/output/
/logs/

# Python tooling used only for training/export
venv/
__pycache__/
*.pyc
*.pt
