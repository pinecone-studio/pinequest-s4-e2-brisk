# Normalize line endings across Windows + macOS/Linux teammates.
# All text files are stored as LF in the repo and checked out as-is.
* text=auto eol=lf

# Explicit text types (kept LF everywhere)
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets — never touch line endings
*.pt    binary
*.onnx  binary
*.engine binary
*.wasm  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.woff  binary
*.woff2 binary
