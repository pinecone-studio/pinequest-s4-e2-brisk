# aegis-cctv-front — environment variables
# Copy to .env.local (recommended) or .env.
#
# This project holds NO secrets. All server-side keys (Gemini, UniFi, RTSP)
# live in aegis-cctv-backend. The frontend only needs to know where the
# backend is so its app/api/**/route.ts proxies can forward requests to it.

# ── Backend service location ─────────────────────────────────────────────────
# Used by lib/backendProxy.ts (the app/api proxy handlers) and by the
# /api/camera-service/* rewrite in next.config.ts.
BACKEND_URL=http://localhost:3001

# ── Legacy camera-service origins (browser-exposed) ──────────────────────────
# Consumed directly by app/cameras/lib/universalCameraApi.ts. Point these at the
# backend once its /api/discover/* + WebSocket relay are rebuilt.
CAMERA_SERVICE_ORIGIN=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_HTTP=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_WS=ws://localhost:3001

# ── Demo toggles (optional) ──────────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_REALTIME=1
