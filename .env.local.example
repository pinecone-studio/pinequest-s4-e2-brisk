# Aegis — Frontend (Next.js) environment variables
# Copy this file to .env.local:
#   cp .env.local.example .env.local
#
# See also .env.example at the repo root (same variables).

# ── Gemini vision (required) ─────────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ── Node camera service ───────────────────────────────────────────────────────
CAMERA_SERVICE_ORIGIN=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_HTTP=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_WS=ws://localhost:3001

# ── FFmpeg / RTSP (optional) ──────────────────────────────────────────────────
# FFMPEG_PATH=ffmpeg
# RTSP_PASSWORDS=123456,hk123456
# RTSP_PATHS=/Streaming/Channels/101,/live

# ── Static export (optional — disables API routes) ────────────────────────────
# STATIC_EXPORT=1
