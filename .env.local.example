# Aegis — Frontend (Next.js) environment variables
# Copy this file to .env.local and fill in real values:
#   cp .env.local.example .env.local
#
# .env.local is gitignored by Next.js by default and must never be committed.

# ── FastAPI backend URL ───────────────────────────────────────────────────────
# Base URL of the Python FastAPI server.
# Used by next.config.ts to proxy /api/cameras/* routes to the backend.
# Default is http://localhost:8000 when this variable is unset.
FASTAPI_ORIGIN=http://localhost:8000

# ── Static export mode ────────────────────────────────────────────────────────
# Set to "1" to enable Next.js static export (disables API rewrites).
# Leave unset for standard server-side rendering with API proxying.
STATIC_EXPORT=

# ── Active browser ONNX model ─────────────────────────────────────────────────
# Which smoking ONNX model to load in the browser.
# "pretrained" loads public/models/pretrained.onnx (default, included in repo).
# "finetuned" loads public/models/finetuned.onnx (requires training + export).
NEXT_PUBLIC_ACTIVE_MODEL=pretrained
