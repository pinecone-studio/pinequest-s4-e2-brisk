# Aegis — Backend environment variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored and must never be committed.

# ── Roboflow (required only for training scripts) ────────────────────────────
# Used by scripts/train_model.py, scripts/train_security_model.py, etc.
# Obtain from https://app.roboflow.com → Settings → API Keys
ROBOFLOW_API_KEY=your-roboflow-api-key-here
ROBOFLOW_WORKSPACE=your-workspace-slug
ROBOFLOW_PROJECT=your-smoking-project-slug
ROBOFLOW_VERSION=1

# Roboflow trash dataset (scripts/train_trash_model.py)
ROBOFLOW_TRASH_WORKSPACE=ros
ROBOFLOW_TRASH_PROJECT=trash-plastic-bottle-detection
ROBOFLOW_TRASH_VERSION=2

# Roboflow security/violence dataset (scripts/train_security_model.py)
ROBOFLOW_SECURITY_WORKSPACE=your-security-workspace-slug
ROBOFLOW_SECURITY_PROJECT=your-security-project-slug
ROBOFLOW_SECURITY_VERSION=1

# ── Gemini vision (webcam live AI — app/api/gemini) ──────────────────────────
# Required for the webcam live AI in the Next.js app (and gemini_cctv.py).
# The browser never sees this key; it stays server-side in the /api/gemini route.
# Obtain a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional model override (defaults to gemini-2.5-flash)
GEMINI_MODEL=

# ── Camera discovery ─────────────────────────────────────────────────────────
# Optional. Comma-separated scan targets (CIDR blocks, IPs, or hostnames).
# Defaults to auto-detecting the local subnet if unset.
# Example: CAMERA_DISCOVERY_TARGETS=192.168.1.0/24,10.0.0.0/24
CAMERA_DISCOVERY_TARGETS=

# ── UniFi Protect integration ────────────────────────────────────────────────
# Optional. When set, app/services/camera_discovery.py fetches cameras from
# the UniFi Site Manager API in addition to nmap scanning.
# Obtain from your UniFi console → Settings → API Keys
UNIFI_API_KEY=

# ── YAMNet audio model cache ─────────────────────────────────────────────────
# Optional. Directory where TensorFlow Hub caches the YAMNet model after the
# first download. Set to a persistent path to avoid re-downloading on every
# cold start. If unset, TF Hub uses its default system temp cache.
TFHUB_CACHE_DIR=models/yamnet_cache

# Optional. If you have downloaded YAMNet as a local SavedModel directory,
# set this path to load it without a network call.
# YAMNET_LOCAL_PATH=models/yamnet
