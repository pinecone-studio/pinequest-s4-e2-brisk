# Pinequest / Aegis — environment variables
# Copy to .env.local for Next.js (recommended) or .env at repo root:
#   cp .env.example .env.local
#
# Never commit real API keys.

# ── Gemini vision (required for live camera AI) ──────────────────────────────
# Server-side only — used by app/api/gemini/route.ts. The browser never sees it.
# Obtain at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ── Node camera service (ONVIF discovery + RTSP relay) ─────────────────────────
# Run separately: npm run dev:camera-service
CAMERA_SERVICE_ORIGIN=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_HTTP=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_WS=ws://localhost:3001

# ── FFmpeg (RTSP → MJPEG) ────────────────────────────────────────────────────
# Leave unset to use `ffmpeg` on PATH.
# FFMPEG_PATH=ffmpeg

# ── RTSP fallbacks (optional) ────────────────────────────────────────────────
# RTSP_PASSWORDS=123456,hk123456
# RTSP_PATHS=/Streaming/Channels/101,/live,/h264

# ── Camera discovery targets (optional) ──────────────────────────────────────
# CAMERA_DISCOVERY_TARGETS=192.168.1.0/24

# ── UniFi Protect (optional) ───────────────────────────────────────────────────
# UNIFI_API_KEY=
